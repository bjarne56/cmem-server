  "query": "\n        SELECT\n            token_hash AS \"token_hash!: String\",\n            user_id    AS \"user_id!: String\",\n            issued_at  AS \"issued_at!: i64\",\n            expires_at AS \"expires_at!: i64\",\n            revoked    AS \"revoked!: i64\"\n        FROM refresh_tokens\n        WHERE token_hash = ?1\n          AND revoked = 0\n          AND expires_at > ?2\n        ",
